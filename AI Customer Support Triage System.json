              "content": "=Analyze the following support request:\n\nSubject:\n{{ $('Gmail Trigger').item.json.Subject }}\n\nCustomer:\n{{ $json.name }}\n\nMessage:\n{{ $('Gmail Trigger').item.json.snippet }}"
