# Google AI Studio / Gemini API key (embeddings + chat)
GOOGLE_API_KEY=

# Optional model overrides
EMBEDDING_MODEL=gemini-embedding-001
CHAT_MODEL=gemini-2.5-flash

# Qdrant Cloud
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=portfolio_kb

# RAG tuning
RAG_TOP_K=6
# Qdrant Cosine similarity: higher = more similar. Reject when best score < threshold.
RAG_SCORE_THRESHOLD=0.55

# Comma-separated origins allowed to call /api/chat
ALLOWED_ORIGINS=https://ngocdiep.dev,http://localhost:3000,http://127.0.0.1:5500
